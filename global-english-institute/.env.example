# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Resend Email API
RESEND_API_KEY=re_your_resend_api_key

# Note: These values are used at build time via the Angular environment files.
# For Vercel deployments, set these as environment variables in the Vercel dashboard.
# For local development, create src/environments/environment.ts and fill in real values.
